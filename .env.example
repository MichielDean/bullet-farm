# Cistern — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never baked into the image.
#
# Usage:
#   docker run -it --env-file .env -v cistern-data:/root/.cistern ghcr.io/michiieldean/cistern

# ── Provider credentials ────────────────────────────────────────────────────
# Opencode (the agent CLI) uses GH_TOKEN for GitHub API access.
# LLM API credentials (e.g. ANTHROPIC_BASE_URL, OPENAI_BASE_URL) are only
# needed if you configure the llm: block in cistern.yaml for ct filter/refine.

GH_TOKEN=your_github_token_here

# ── Optional overrides ────────────────────────────────────────────────────────
# CT_DB=/root/.cistern/cistern.db
# CT_CONFIG=/root/.cistern/cistern.yaml
