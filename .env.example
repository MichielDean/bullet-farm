# Cistern — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never baked into the image.
#
# Usage:
#   docker run -it --env-file .env -v cistern-data:/root/.cistern ghcr.io/michiieldean/cistern

# ── Required for headless / non-interactive deployments ──────────────────────
# If omitted, the entrypoint will prompt for browser-based OAuth on first run
# (requires: docker run -it ...).

GH_TOKEN=your_github_token_here

# ── Optional overrides ────────────────────────────────────────────────────────
# CT_DB=/root/.cistern/cistern.db
# CT_CONFIG=/root/.cistern/cistern.yaml
